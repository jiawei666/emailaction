# ============================================================================
# EmailAction 环境变量配置
# ============================================================================
# 复制此文件为 .env.local 并填入实际值
# 获取 API 密钥: https://open.bigmodel.cn (智谱AI)

# ----------------------------------------------------------------------------
# 数据库配置
# ----------------------------------------------------------------------------
# PostgreSQL 连接串（本项目已切换为 PostgreSQL）
# 本地可用 Neon/Supabase/Railway，或本机 PostgreSQL
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/emailaction?schema=public"

# ----------------------------------------------------------------------------
# NextAuth.js 认证配置
# ----------------------------------------------------------------------------
NEXTAUTH_URL="http://localhost:3000"
# 生产环境: NEXTAUTH_URL="https://yourdomain.com"

# 生成密钥: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-key-change-in-production-use-openssl-rand-base64-32"

# ----------------------------------------------------------------------------
# Google OAuth (必需 - 用于 Gmail 集成)
# ----------------------------------------------------------------------------
# 获取方式: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
# 可选，默认为 http://localhost:3000/api/auth/callback/google
# GOOGLE_REDIRECT_URI="http://localhost:3000/api/auth/callback/google"

# ----------------------------------------------------------------------------
# GitHub OAuth (可选 - 用于登录)
# ----------------------------------------------------------------------------
GITHUB_CLIENT_ID="your-github-client-id"
GITHUB_CLIENT_SECRET="your-github-client-secret"

# ----------------------------------------------------------------------------
# AI 任务提取 (必需 - 智谱 GLM-4)
# ----------------------------------------------------------------------------
# 获取方式: https://open.bigmodel.cn/usercenter/apikeys
GLM_API_KEY="your-glm-api-key"
# 可选，使用 CRS 代理时配置:
# GLM_API_URL="https://your-crs-proxy.com"

# ----------------------------------------------------------------------------
# Gmail 推送通知 (可选 - 用于实时监听)
# ----------------------------------------------------------------------------
# GMAIL_PUBSUB_TOPIC="projects/YOUR_PROJECT/topics/gmail-watch"

# ----------------------------------------------------------------------------
# 飞书集成 (可选)
# ----------------------------------------------------------------------------
FEISHU_APP_ID="your-feishu-app-id"
FEISHU_APP_SECRET="your-feishu-app-secret"
# 可选，默认为 http://localhost:3000/api/feishu/callback
# FEISHU_REDIRECT_URI="http://localhost:3000/api/feishu/callback"

# ----------------------------------------------------------------------------
# Cron 任务密钥 (生产环境必需)
# ----------------------------------------------------------------------------
# 用于保护定时任务端点，建议使用强密码
# 生成方式: openssl rand -base64 32
CRON_SECRET="your-cron-secret-key"

# ----------------------------------------------------------------------------
# Notion OAuth (可选 - 保留用于未来 OAuth 集成)
# ----------------------------------------------------------------------------
NOTION_CLIENT_ID="your-notion-client-id"
NOTION_CLIENT_SECRET="your-notion-client-secret"
NOTION_REDIRECT_URI="http://localhost:3000/api/notion/callback"

# ----------------------------------------------------------------------------
# Todoist OAuth (可选 - 保留用于未来 OAuth 集成)
# ----------------------------------------------------------------------------
TODOIST_CLIENT_ID="your-todoist-client-id"
TODOIST_CLIENT_SECRET="your-todoist-client-secret"
TODOIST_REDIRECT_URI="http://localhost:3000/api/todoist/callback"
